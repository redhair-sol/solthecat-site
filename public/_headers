/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://solcam.solthecat.com https://cloudflareinsights.com; frame-src https://docs.google.com; media-src 'self' https://solcam.solthecat.com blob:; object-src 'none'; base-uri 'self'; form-action 'self' https://docs.google.com

/sitemap.xml
  Content-Type: application/xml

/robots.txt
  Content-Type: text/plain
